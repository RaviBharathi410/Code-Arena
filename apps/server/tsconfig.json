{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@arena/database": [
                "../../packages/database/schema.ts"
            ],
            "@arena/shared/*": [
                "../../packages/shared/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../../packages/database/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}